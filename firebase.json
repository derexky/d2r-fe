{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "../d2r-service",
      "codebase": "d2r-api",
      "predeploy": ["npm --prefix ../d2r-service run build"]
    }
  ]
}
